APP_NAME="Resume Intelligence Backend"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
API_V1_PREFIX="/api/v1"
LOG_LEVEL="INFO"

MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB_NAME="resume_intelligence"
REDIS_URL="redis://127.0.0.1:6379/0"
FILE_STORAGE_PATH="uploads/resumes"
FRONTEND_ORIGINS="http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173"
MAX_RESUME_UPLOAD_SIZE_MB=10
AUTH_SECRET_KEY="change-this-secret-key"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SMTP_HOST="127.0.0.1"
SMTP_PORT=1025
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
EMAIL_FROM_ADDRESS="noreply@resumex.local"
EMAIL_FROM_NAME="ResumeAI Recruitment"
EMAIL_RETRY_COUNT=2
EMAIL_RETRY_DELAY_SECONDS=3
SEND_UNDER_REVIEW_EMAILS=true

DEFAULT_EMBEDDING_MODEL="all-MiniLM-L6-v2"
ENABLE_TRANSFORMER_SIMILARITY=true
ENABLE_LLM_EXPLANATIONS=false
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-1.5-flash"
LLM_API_KEY=""

CELERY_TASK_ALWAYS_EAGER=false
MLFLOW_TRACKING_URI="file:./mlruns"
MINIO_ENDPOINT="127.0.0.1:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="resume-files"
